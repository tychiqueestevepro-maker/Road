{
  "name": "@road-reality/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./ingestion": "./src/ingestion.ts",
    "./engine-runner": "./src/engine-runner.ts",
    "./demo": "./src/demo.ts",
    "./camera-pipeline": "./src/camera-pipeline.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "worker": "tsx src/index.ts worker",
    "ingest:once": "tsx src/index.ts ingest:once",
    "cameras:sync:caltrans": "tsx src/index.ts cameras:sync:caltrans",
    "demo:seed": "tsx src/index.ts demo:seed",
    "demo:run": "tsx src/index.ts demo:run",
    "dev": "tsx watch src/index.ts worker"
  },
  "dependencies": {
    "@road-reality/config": "workspace:*",
    "@road-reality/connectors": "workspace:*",
    "@road-reality/database": "workspace:*",
    "@road-reality/road-engine": "workspace:*",
    "@road-reality/shared": "workspace:*",
    "@road-reality/vision": "workspace:*",
    "dotenv": "^16.4.7",
    "pino": "^9.5.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
