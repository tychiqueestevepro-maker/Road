# APPLICATION
NODE_ENV=development
WEB_PORT=3000
API_PORT=4000
VISION_PORT=5000

NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=
NEXT_PUBLIC_MAPBOX_STYLE_URL=mapbox://styles/mapbox/streets-v12
NEXT_PUBLIC_MAP_STYLE_URL=
MAPBOX_ACCESS_TOKEN=
MAPBOX_GEOCODING_ENABLED=true
MAPBOX_GEOCODING_PERMANENT=false
MAPBOX_GEOCODING_MAX_EVENTS_PER_RESPONSE=20
LIVE_EVENT_DISPLAY_TTL_SECONDS=300

# DATABASE
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/verytis
DATABASE_POOL_MAX=10

# 511 SF BAY
SF511_API_KEY=
SF511_EVENTS_POLL_SECONDS=60
SF511_WZDX_POLL_SECONDS=60

# DATASF / SOCRATA
SOCRATA_APP_TOKEN=
DATASF_CLOSURES_POLL_SECONDS=300

# CAMERAS
CAMERA_POLL_SECONDS=30
CAMERA_FETCH_TIMEOUT_MS=10000

# ROAD ENGINE
ROAD_EVENT_MATCH_RADIUS_METERS=100
CAMERA_OBSERVATION_STALE_SECONDS=120
TRAFFIC_OBSERVATION_STALE_SECONDS=300
DISCREPANCY_MIN_SCORE=0.70

# VISION
# Use VISION_PROVIDER=external with an OpenAI key only when you want paid remote vision analysis.
VISION_PROVIDER=local
VISION_API_KEY=
VISION_MODEL=
VISION_SERVICE_URL=http://localhost:5000

# DEMO
DEMO_MODE=true

# LOGGING
LOG_LEVEL=info

# PUBLIC API
PUBLIC_API_BASE_URL=https://api.verytis.dev/v1
API_KEY_HASH_SECRET=
API_RATE_LIMIT_PER_MINUTE=600
API_ACCESS_REQUEST_COOLDOWN_MINUTES=15
API_ACCESS_ALLOW_ADDITIONAL_KEYS=true
API_MAX_ACTIVE_KEYS_PER_CONSUMER=3
ACCESS_RATE_LIMIT_PER_HOUR=5
API_ALLOWED_ORIGINS=http://localhost:3000

# EMAIL
RESEND_API_KEY=
EMAIL_FROM=Verytis <api@verytis.dev>
EMAIL_REPLY_TO=

# WEBHOOKS
WEBHOOK_SIGNING_SECRET=
